root:
  - env: {{agent_app_name|upper}}_PORT
    type: string
    default: "8842"
    help: "Enter the local port to access the agent. Should be a unique value."
{% if use_agent_memory == 'mem0' %}
  - env: MEM0_API_KEY
    type: secret_string
    optional: false
    help: |
      Enter your Mem0 API key for agent memory.
      Obtain one from https://app.mem0.ai/
{% endif %}
  - env: DATAROBOT_DEFAULT_EXECUTION_ENVIRONMENT
    type: string
    default: "[DataRobot] Python 3.11 GenAI Agents"
    optional: true
    help: "Enter the default execution environment for the agent's custom model."
  - env: DATAROBOT_DEFAULT_EXECUTION_ENVIRONMENT_VERSION_ID
    type: string
    default: "6a3919cb62ca0dc60197d473"
    optional: true
    help: |
      Enter the default execution environment version ID for the agent's
      custom model.
  - env: ENABLE_DRAGENT_SERVER
    type: string
    default: "true"
    optional: true
    help: "Whether to use the `dragent` as frontserver for your agent"
{% if use_agent_memory == 'datarobot_memory_service' %}

# Shown only when the LLM component's External LLM option is selected (external_llm section).
external_llm:
  - key: agent_memory_llm_routing
    optional: true
    help: |
      Your agent LLM uses external provider credentials, which cannot
      back the DataRobot Memory Service memory space directly. Choose a
      dedicated LLM for memory indexing.
      You can also set AGENT_MEMORY_LLM_MODEL_NAME or
      AGENT_MEMORY_LLM_DEPLOYMENT_ID in .env to override routing.
    options:
      - name: "LLM Gateway"
        value: "gateway"
        requires: agent_memory_llm_gateway
      - name: "Deployed LLM"
        value: "deployed"
        requires: agent_memory_llm_deployed

agent_memory_llm_gateway:
  - env: AGENT_MEMORY_LLM_MODEL_NAME
    type: llmgw_catalog
    optional: false
    help: |
      Choose an LLM Gateway model for the DataRobot Memory Service
      memory space.

agent_memory_llm_deployed:
  - env: AGENT_MEMORY_LLM_DEPLOYMENT_ID
    type: string
    optional: false
    help: "Enter the deployment ID for the memory space LLM."
{% endif %}
