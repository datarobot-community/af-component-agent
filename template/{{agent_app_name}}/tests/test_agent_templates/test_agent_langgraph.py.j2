    @patch("agent.myagent.ChatLiteLLM")
    def test_llm_openai_compatible_endpoint(self, mock_llm):
        """When openai_api_base is set, use ChatLiteLLM with openai/ model prefix."""
        with patch.dict(os.environ, {}, clear=True):
            agent = MyAgent(api_key="dr-key")
            _reset_llm_config_for_tests(agent)
            agent.config.openai_api_base = "http://localhost:11434/v1"
            agent.config.openai_api_token = "compat-token"
            agent.default_model = "llama3"
            agent.llm()
            mock_llm.assert_called_once_with(
                model="openai/llama3",
                api_base="http://localhost:11434/v1",
                api_key="compat-token",
                timeout=90,
                streaming=True,
                max_retries=3,
            )

