from unittest.mock import MagicMock, Mock

import pytest
from llama_index.core.tools import BaseTool

from agent import MyAgent
from agent.myagent import (
    agent_planner,
    agent_writer,
    agents,
    extract_response_text,
    workflow,
)


class TestMyAgentLlamaIndex:
    @pytest.fixture
    def agent(self):
        mock_llm = Mock()
        return MyAgent(llm=mock_llm, verbose=True)

    def test_myagent_is_llamaindex_agent_subclass(self):
        """Test that MyAgent inherits from LlamaIndexAgent."""
        from datarobot_genai.llama_index.agent import LlamaIndexAgent

        assert issubclass(MyAgent, LlamaIndexAgent)

    def test_init_with_llm(self):
        """Test initialization with an LLM instance."""
        mock_llm = Mock()
        agent = MyAgent(llm=mock_llm, verbose=True)
        assert agent.llm == mock_llm
        assert agent.verbose is True

    def test_module_level_agents_defined(self):
        """Test that module-level agents are properly defined."""
        assert len(agents) == 2
        assert agent_planner.name == "planner_agent"
        assert agent_writer.name == "writer_agent"

    def test_planner_can_handoff_to_writer(self):
        """Test that planner agent can hand off to writer."""
        assert "writer_agent" in agent_planner.can_handoff_to

    def test_workflow_defined(self):
        """Test that the workflow is properly configured."""
        assert workflow is not None

    def test_extract_response_text_from_state(self):
        """Test extracting response from workflow state."""
        state = {"report_content": "Test report content"}
        result = extract_response_text(state, [])
        assert result == "Test report content"

    def test_extract_response_text_from_events(self):
        """Test extracting response from events when state is empty."""
        mock_event = Mock()
        mock_event.response = Mock(content="Event content")
        result = extract_response_text({}, [mock_event])
        assert result == "Event content"

    def test_extract_response_text_empty(self):
        """Test extracting response when both state and events are empty."""
        result = extract_response_text({}, [])
        assert result == ""

    def test_set_tools_propagates_to_agents(self):
        """Test that set_tools propagates tools to all sub-agents."""
        mock_llm = Mock()
        mock_tool = MagicMock(spec=BaseTool)
        agent = MyAgent(llm=mock_llm, tools=[mock_tool])
        for sub_agent in agents:
            assert mock_tool in sub_agent.tools
