import inspect

from nat.data_models.agent import AgentBaseConfig

from agent.register import LanggraphAgentConfig, langgraph_agent


class TestRegisterModule:
    def test_config_class_extends_agent_base_config(self):
        assert issubclass(LanggraphAgentConfig, AgentBaseConfig)

    def test_registered_function_exists(self):
        assert callable(langgraph_agent)

    def test_registered_function_is_async(self):
        assert inspect.iscoroutinefunction(langgraph_agent) or inspect.isasyncgenfunction(langgraph_agent)
