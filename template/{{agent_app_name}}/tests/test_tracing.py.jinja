"""Verify tracing is wired for the dragent execution path."""

from opentelemetry.instrumentation.fastapi import FastAPIInstrumentor
from opentelemetry.instrumentation.requests import RequestsInstrumentor


def test_fastapi_is_instrumented_after_register_import():
    import agent.register  # noqa: F401

    assert FastAPIInstrumentor().is_instrumented_by_opentelemetry


def test_requests_is_instrumented_after_register_import():
    import agent.register  # noqa: F401

    assert RequestsInstrumentor().is_instrumented_by_opentelemetry
