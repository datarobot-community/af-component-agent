import uuid
from collections.abc import AsyncGenerator
from contextlib import asynccontextmanager
from typing import TYPE_CHECKING, Any, Optional

from ag_ui.core import (
    EventType,
    RunAgentInput,
    RunFinishedEvent,
    RunStartedEvent,
    TextMessageContentEvent,
    TextMessageEndEvent,
    TextMessageStartEvent,
)
from datarobot_genai.core.agents import (
    BaseAgent,
    InvokeReturn,
    UsageMetrics,
    default_usage_metrics,
    extract_user_prompt_content,
)
from datarobot_genai.core.chat import agent_chat_completion_wrapper
from datarobot_genai.core.mcp import MCPConfig
from openai.types.chat import CompletionCreateParams

if TYPE_CHECKING:
    from ragas import MultiTurnSample


@asynccontextmanager
async def mcp_tools_context(
    mcp_config: MCPConfig,
) -> AsyncGenerator[list[Any], None]:
    """No-op MCP tools context for the base agent (no framework-specific MCP adapter)."""
    yield []


class MyAgent(BaseAgent[None]):
    """MyAgent is a generic base class that can be used for creating a custom agentic flow. This template
    implements the minimum required methods and attributes to function as a DataRobot agent.
    """

    async def invoke(self, run_agent_input: RunAgentInput) -> InvokeReturn:
        """Run the agent with the provided completion parameters.

        [THIS METHOD IS REQUIRED SO THE SERVER CAN CALL THE AGENT]

        Args:
            run_agent_input: User inputs and parameters for running the agent, encapsulated in a RunAgentInput object.
        Returns:
            An async generator yielding tuples of (Event, pipeline_interactions, usage_metrics).
        """
        user_prompt_content = extract_user_prompt_content(run_agent_input)

        print("Running agent with user prompt:", user_prompt_content, flush=True)

        usage_metrics: UsageMetrics = default_usage_metrics()
        thread_id = run_agent_input.thread_id
        run_id = run_agent_input.run_id
        message_id = str(uuid.uuid4())

        yield (
            RunStartedEvent(
                type=EventType.RUN_STARTED, thread_id=thread_id, run_id=run_id
            ),
            None,
            usage_metrics,
        )

        # -----------------------------------------------------------
        # Here you would implement the streaming logic of your agent using the inputs.
        # Yield TextMessageContentEvent chunks as your agent produces output.
        # -----------------------------------------------------------
        yield (
            TextMessageStartEvent(
                type=EventType.TEXT_MESSAGE_START,
                message_id=message_id,
                role="assistant",
            ),
            None,
            usage_metrics,
        )
        yield (
            TextMessageContentEvent(
                type=EventType.TEXT_MESSAGE_CONTENT,
                message_id=message_id,
                delta="streaming success",
            ),
            None,
            usage_metrics,
        )
        yield (
            TextMessageEndEvent(
                type=EventType.TEXT_MESSAGE_END,
                message_id=message_id,
            ),
            None,
            usage_metrics,
        )

        events: list[Any] = []

        pipeline_interactions = self.create_pipeline_interactions_from_events(events)

        yield (
            RunFinishedEvent(
                type=EventType.RUN_FINISHED, thread_id=thread_id, run_id=run_id
            ),
            pipeline_interactions,
            usage_metrics,
        )


async def custompy_adaptor(
    completion_create_params: CompletionCreateParams,
) -> InvokeReturn | tuple[str, Optional["MultiTurnSample"], UsageMetrics]:
    forwarded_headers = completion_create_params.get("forwarded_headers", {})
    authorization_context = completion_create_params.get("authorization_context", {})
    mcp_config = MCPConfig(
        forwarded_headers=forwarded_headers,
        authorization_context=authorization_context,
    )
    async with mcp_tools_context(mcp_config) as mcp_tools:
        agent = MyAgent(
            verbose=completion_create_params.get("verbose", True),  # type: ignore[arg-type]
            timeout=completion_create_params.get("timeout", 90),  # type: ignore[arg-type]
            tools=mcp_tools,
            forwarded_headers=forwarded_headers,  # type: ignore[arg-type]
        )
        return await agent_chat_completion_wrapper(agent, completion_create_params)
