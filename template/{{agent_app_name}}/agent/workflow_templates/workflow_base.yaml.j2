general:
  front_end:
    _type: dragent_fastapi
    # Step adaptor is not necessary for custom agents
    step_adaptor:
      mode: "off"
    # If you don't want your agent to expose A2A endpoints, remove the following block.
    a2a:
      server:
        name: "Base Agent"
        description: "A custom base agent."
      skills: # Optional: advertise specific skills in the agent card
        - id: base_agent
          name: "Base Agent"
          description: "Runs the base agent."
          tags: []
          examples: []
      # Optional: Okta cross-application access (XAA) authentication for this agent's A2A endpoints.
      # Uncomment to advertise XAA requirements on the agent card. See docs/agent/agent2agent-auth.md.
      # cross_application_access:
      #   token_exchange:
      #     trusted_issuer: "https://your-org.okta.com"
      #     audience: "https://your-org.okta.com/oauth2/ausXXXXXXXXXXXXXXX"
      #   token_request:
      #     token_url: "https://your-org.okta.com/oauth2/ausXXXXXXXXXXXXXXX/v1/token"
      #     audience: "https://app.datarobot.com/<org_id>/<agent_id>"
      #     scopes:
      #       - "dr.impersonation"
      # Optional: external identity and URL overrides published on the agent card.
      # external:
      #   id: "my-agent-id"
      #   url: "https://my-agent-id.example.com/a2a/"
# To connect this agent to a remote A2A agent, uncomment the block below and add the
# function group name to the workflow's tool_names list.
# For Okta XAA auth, use auth_provider: okta_auth instead of datarobot_auth.
# function_groups:
#   remote_agent:
#     _type: authenticated_a2a_client
#     url: "https://app.datarobot.com/api/v2/deployments/<deployment-id>/directAccess/a2a/"
#     auth_provider: datarobot_auth

{% if use_agent_memory == 'mem0' %}
functions:
  base_agent:
    _type: base_agent
    llm_name: datarobot_llm
    description: Base agent example

{% endif %}
llms:
  datarobot_llm:
    _type: datarobot-llm-component
  # To enable LLM provider fallback/failover, remove the datarobot_llm block above and uncomment the following:
  # datarobot_llm:
  #   _type: datarobot-llm-router
  #   primary:
  #     use_datarobot_llm_gateway: true
  #     llm_default_model: azure/gpt-5-mini-2025-08-07
  #   fallbacks:
  #     - use_datarobot_llm_gateway: true
  #       llm_default_model: anthropic/claude-opus-4-20250514
  #   num_retries: 1

{% if use_agent_memory == 'mem0' %}
memory:
  mem0_memory:
    _type: dr_mem0_memory

workflow:
  _type: auto_memory_agent
  inner_agent_name: base_agent
  memory_name: mem0_memory
  llm_name: datarobot_llm
  description: Base agent example with automatic memory capture and retrieval
{% else %}
workflow:
  _type: base_agent
  llm_name: datarobot_llm
  description: Base agent example
{% endif %}

authentication:
  datarobot_auth:
    _type: datarobot_api_key
  # Uncomment for Okta XAA authentication (requires PRINCIPAL_ID and PRIVATE_JWK env vars):
  # okta_auth:
  #   _type: okta_cross_app_access
