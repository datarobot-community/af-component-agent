general:
  front_end:
    _type: dragent_fastapi
    # If you don't want your agent to expose A2A endpoints, remove the following block.
    a2a:
      server:
        name: "Blog Content Writer"
        description: "An AI content writing agent that researches and writes well-structured blog posts. Provide a topic and it will generate a concise, publication-ready article in markdown format."
      skills:  # Optional: advertise specific skills in the agent card
        - id: write_blog
          name: "Write Blog Post"
          description: "Researches and writes a blog post on the given topic."
          tags: []
          examples:
            - "Write a blog post about the future of AI in healthcare"
            - "Create an article about sustainable energy trends"
# To connect this agent to a remote A2A agent, uncomment the block below and add the
# function group name to the workflow's tool_names list. You are also free to use environment
# variables like `url: "${AGENT_URL:-http://localhost:8842}"`
# function_groups:
#   remote_agent:
#     _type: a2a_client
#     url: "https://my-remote-agent.example.com"
llms:
  datarobot_llm:
    _type: datarobot-llm-component

workflow:
  _type: llamaindex_agent
  llm_name: datarobot_llm
  description: LlamaIndex planner/writer agent
  # tool_names:
  #   - remote_agent
