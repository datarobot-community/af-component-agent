general:
  telemetry:
    tracing:
      otelcollector:
        _type: datarobot_otelcollector
        project: "agent"
  front_end:
    _type: dragent_fastapi
    # If you don't want your agent to expose A2A endpoints, remove the following block.
    a2a:
      server:
        name: "Blog Content Writer"
        description: "An AI content writing agent that researches and writes well-structured blog posts. Provide a topic and it will generate a concise, publication-ready article in markdown format."
      skills: # Optional: advertise specific skills in the agent card
        - id: write_blog
          name: "Write Blog Post"
          description: "Researches and writes a blog post on the given topic."
          tags: []
          examples:
            - "Write a blog post about the future of AI in healthcare"
            - "Create an article about sustainable energy trends"
            # Optional: Okta cross-application access (XAA) authentication for this agent's A2A endpoints.
            # Uncomment to advertise XAA requirements on the agent card. See docs/agent/agent2agent-auth.md.
            # cross_application_access:
            #   token_exchange:
            #     trusted_issuer: "https://your-org.okta.com"
            #     audience: "https://your-org.okta.com/oauth2/ausXXXXXXXXXXXXXXX"
            #   token_request:
            #     token_url: "https://your-org.okta.com/oauth2/ausXXXXXXXXXXXXXXX/v1/token"
            #     audience: "https://example.com/agents/my-agent-id"
            #     scopes:
            #       - "dr.impersonation"
            # Optional: external identity and URL overrides published on the agent card.
            # external:
            #   id: "my-agent-id"
            #   url: "https://my-agent-id.example.com/a2a/"
functions:
  planner:
    _type: chat_completion
    llm_name: datarobot_llm
    system_prompt: |
      You are a content planner. You create brief, structured outlines for blog articles.
      You identify the most important points and cite relevant sources. Keep it simple and to the point -
      this is just an outline for the writer.

      Create a simple outline with:
      1. 10-15 key points or facts (bullet points only, no paragraphs)
      2. 2-3 relevant sources or references
      3. A brief suggested structure (intro, 2-3 sections, conclusion)

      Do NOT write paragraphs or detailed explanations. Just provide a focused list.
    description: A tool that plans the content for the requested topic.
  writer:
    _type: chat_completion
    llm_name: datarobot_llm
    system_prompt: |
      You are a content writer working with a planner colleague.
      You write opinion pieces based on the planner's outline and context. You provide objective and
      impartial insights backed by the planner's information. You acknowledge when your statements are
      opinions versus objective facts.

      1. Use the content plan to craft a compelling blog post.
      2. Structure with an engaging introduction, insightful body, and summarizing conclusion.
      3. Sections/Subtitles are properly named in an engaging manner.
      4. CRITICAL: Keep the total output under 500 words. Each section should have 1-2 brief paragraphs.

      Write in markdown format, ready for publication.
    description: A tool that writes the content for the requested topic.
{%- if use_agent_memory in ['mem0', 'datarobot_memory_service'] %}
  nat_agent:
    # `streaming_memory_agent` is itself per-user (registered via `register_per_user_function`),
    # so it builds lazily inside the per-user builder and `builder.get_function(inner_agent_name)`
    # can resolve per-user inner agents from the per-user cache. That means we can use
    # `per_user_tool_calling_agent` here and reference per-user function groups (e.g. `mcp_tools`)
    # in `tool_names` below.
    _type: per_user_tool_calling_agent
    llm_name: datarobot_llm
    description: "Blog content orchestrator that plans and writes a blog post."
    tool_names:
      - planner
      - writer
      - mcp_tools
      # Uncomment to inject A2A remote agent tools (must also uncomment function_groups.remote_agent below):
      # - remote_agent
    system_prompt: |
      You are a blog content orchestrator. For every user request, you MUST follow these steps in order:
      1. Call planner to get a content plan.
      2. Call writer with the content plan as input to produce the final blog post.
      You also have access to additional tools (e.g. MCP tools) — use them when they are relevant to fulfilling the request.
      Return only the final blog post output from the writer.
{%- endif %}
function_groups:
  mcp_tools:
    _type: datarobot_mcp_client
    # To connect this agent to a remote A2A agent, uncomment the block below and add the
    # function group name to the workflow's tool_names list.
    # For Okta XAA auth, use auth_provider: okta_auth instead of datarobot_auth.
    #remote_agent:
    #  _type: authenticated_a2a_client
    #  url: "https://app.datarobot.com/api/v2/deployments/<deployment-id>/directAccess/a2a/"
    #  auth_provider: datarobot_auth
authentication:
  datarobot_mcp_auth:
    _type: datarobot_mcp_auth
  datarobot_auth:
    _type: datarobot_api_key
  # Uncomment for Okta XAA authentication (requires IDP_AGENT_ID and IDP_AGENT_PRIVATE_KEY_JWK env vars):
  # okta_auth:
  #   _type: okta_cross_app_access
llms:
  datarobot_llm:
    _type: datarobot-llm-component

{%- if use_agent_memory in ['mem0', 'datarobot_memory_service'] %}
memory:
  mem0_memory:
    _type: dr_mem0_memory

workflow:
  _type: streaming_memory_agent
  inner_agent_name: nat_agent
  memory_name: mem0_memory
  llm_name: datarobot_llm
  description: "Blog content orchestrator with automatic memory capture and retrieval."
{% else %}
workflow:
  _type: per_user_tool_calling_agent
  llm_name: datarobot_llm
  tool_names:
    - planner
    - writer
    - mcp_tools
    # Uncomment to inject A2A remote agent tools (must also uncomment function_groups.remote_agent above):
    # - remote_agent
  system_prompt: |
    You are a blog content orchestrator. For every user request, you MUST follow these steps in order:
    1. Call planner to get a content plan.
    2. Call writer with the content plan as input to produce the final blog post.
    You also have access to additional tools (e.g. MCP tools) — use them when they are relevant to fulfilling the request.
    Return only the final blog post output from the writer.
# Uncomment to use moderations when dragent is enabled
# middleware:
# - datarobot_moderation
{%- endif %}

middleware:
  datarobot_moderation:
    # Guards can be configured inline by adding the moderation field here.
    # See the Guardrails Configuration Guide at https://pypi.org/project/datarobot-moderations/
    # If there is no inline configuration then moderation_config.yaml will be loaded, if present.
    # If no guards are configured then the middleware is a no-op.
    _type: datarobot_moderation
